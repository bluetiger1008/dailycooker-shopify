<div data-section-id="{{ section.id }}" data-section-type="section-service-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-service-v1">
    <div class="container container-v2">
      <div class="row js-service-v1">
        {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
        {% if block.type == "service" %}
        <div class="itemtservice justify-content-center col-12">
          <div class="box-service" style="background: {{ block.settings.bg_item }}">
            <div class="number">
              {% if block.settings.img_icon != blank %}
              <img loading="lazy" width="" height="" src="{{ block.settings.img_icon | image_url }}">
              {% else %}
              {{ block.settings.block_number }}
              {% endif %}
            </div>

            <div class="info">
              {% if block.settings.block_title != blank %}
              <h4 class="title">{{ block.settings.block_title }}</h4>
              {% endif %}
              {% if block.settings.block_content != blank %}          	
              <p class="content">{{ block.settings.block_content }}</p>
              {% endif %}
            </div>
          </div>
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "SERVICE V1",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service item",
      "settings": [
        {
          "type": "color",
          "id": "bg_item",
          "label": "Background item",
          "default": "#f4f4f4"
        },
        {
          "type": "text",
          "id": "block_number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "image_picker",
          "id": "img_icon",
          "label": "Image icon"
        },
        {
          "type": "text",
          "id": "block_title",
          "label": "Title",
          "default": "FREE SHIPPING"
        },
        {
          "type": "text",
          "id": "block_content",
          "label": "Content",
          "default": "Free shipping all order"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SERVICE V1",
      "category": "HOME",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "block_number": "1",
            "block_title": "FREE SHIPPING",
            "block_content": "Free shipping all order"
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "2",
            "block_title": "SUPPORT 24/7",
            "block_content": "Support 24 hours a day"
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "3",
            "block_title": "MONEY RETURN",
            "block_content": "30 days for free return"
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "4",
            "block_title": "ORDER DISCOUNT",
            "block_content": "On every order over $15"
          }
        }
      ]
    }
  ]
}
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
