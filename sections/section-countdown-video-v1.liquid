<div data-section-id="{{ section.id }}" data-section-type="section-countdown-video-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-countdown-video-v1 section-countdown-video-v1-{{ section }} mt-all">
    <div class="container container-v2">
      <div class="row align-items-center row-banner-{{ section.id }}">
        <div class="col-md-6">
          <div class="box-info-content text-center">
            {% if section.settings.banner_img != blank %}
            <img loading="lazy" width="" height="" data-src="{{ section.settings.banner_img | image_url }}" class="lazyload img-fluid w-100" alt="_img_banner_">
            {% else %}
            <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/800x800" class="lazyload img-fluid w-100" alt="_img_banner_">
            {% endif %}
            <div class=" content-section">
              <div class=" info-deal">
                <div class="m-auto">

                  {% if section.settings.title-top != blank %}
                  <div class="title-top" style="color:{{ section.settings.color_sub_title }}">{{ section.settings.title-top }}</div>
                  {% endif %}
                  {% if section.settings.title != blank %}
                  <div class="title" style="color:{{ section.settings.color_title }}">{{ section.settings.title }}</div>
                  {% endif %}

                </div>
              </div>

              <div class="countdown-timer">
                <ul class="mb-0" data-countdown="countdown-video-v1" data-date="{{ section.settings.countdown-date }}">
                </ul>
              </div> 

              {% if section.settings.buttom_banner != blank %}
              <div class="div-button">
                <a href="{{ section.settings.url_btn }}" class="button"  style="color: {{ section.settings.color_btn }}; background:{{ section.settings.bg_btn }};">
                  {{ section.settings.buttom_banner }}
                </a>
              </div>
              {% endif %}
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="section-video">
            <div class="box-video">
              <div class="video-bg">
                {% if section.settings.video_img != blank %}
                <img loading="lazy" width="" height="" data-src="{{ section.settings.video_img | image_url }}" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% else %}
                <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/800x800" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% endif %}
              </div>
              <div class="video-content">
                <a data-fancybox href="{{ section.settings.url_video1 }}"> 
                  <span class="box-btn">
                    <span class="btn-banner">
                      <i class="fa fa-play"></i>
                      <span class="line-video line-1"></span>
                      <span class="line-video line-2"></span>
                      <span class="line-video line-3"></span>
                    </span>
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .section-countdown-video-v1-{{ section }} .button:hover {
    color : {{ section.settings.color_btn_hover }} !important;
    background : {{ section.settings.bg_btn_hover }} !important;
  }
  .section-countdown-video-v1-{{ section }} .countdown-timer li span {
    color: {{ section.settings.color_countdown }} !important;
  }
  .section-countdown-video-v1-{{ section }} .countdown-timer li {
    color: {{ section.settings.color_subcountdown }} !important;
  }
</style>  


