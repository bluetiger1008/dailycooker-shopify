<div data-section-id="{{ section.id }}" data-section-type="section-banner-v5" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v5 mt-all">
    <div class="container container-v2">
      <div class="row">        
        <div class="col-sm-6">
          <div class="banner-item">
            <div class="box-img">
              <img loading="lazy" width="" height="" data-src="{% if section.settings.img_banner1 != blank %} {{ section.settings.img_banner1 | image_url }} {% else %} //via.placeholder.com/810x550 {% endif %}" class="lazyload img-fluid w-100" alt="_img_banner">
            </div>
            <div class="banner-content">
              {% if section.settings.sub_title1 != blank %}
              <p class="title-top title-top-{{ section.id }}">{{ section.settings.sub_title1 }}</p>
              {% endif %}
              {% if section.settings.title_banner1 != blank %}
              <h3 class="title-banner title-{{ section.id }}">{{ section.settings.title_banner1 }}</h3>
              {% endif %}
              {% if section.settings.btn_banner1 != blank %}
              <a href="{{ section.settings.url_banner1 }}" class="btn-banner btn-banner-{{ section.id }}">{{ section.settings.btn_banner1 }}</a>
              {% endif %}
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="banner-item">
            <div class="box-img">
              <img loading="lazy" width="" height="" data-src="{% if section.settings.img_banner2 != blank %} {{ section.settings.img_banner2 | image_url }} {% else %} //via.placeholder.com/810x550 {% endif %}" class="lazyload img-fluid w-100" alt="_img_banner">
            </div>
            <div class="banner-content">
              {% if section.settings.sub_title2 != blank %}
              <p class="title-top title-top-{{ section.id }}">{{ section.settings.sub_title2 }}</p>
              {% endif %}
              {% if section.settings.title_banner2 != blank %}
              <h3 class="title-banner title-{{ section.id }}">{{ section.settings.title_banner2 }}</h3>
              {% endif %}
              {% if section.settings.btn_banner2 != blank %}
              <a href="{{ section.settings.url_banner2 }}" class="btn-banner btn-banner-{{ section.id }}">{{ section.settings.btn_banner2 }}</a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .section-banner-v5 .banner-item .banner-content .title-top-{{ section.id }} {
    color: {{ section.settings.color_top_title }};
    background: {{ section.settings.bg_top_title }};
    display: inline-block;
    padding: 0 5px;
  }
  .section-banner-v5 .banner-item .banner-content .title-{{ section.id }} {
    color: {{ section.settings.color_title }};
  }
  .section-banner-v5 .banner-item .banner-content .btn-banner-{{ section.id }} {
    color: {{ section.settings.color_btn }};
    transition: all .3s;
    border: 1px solid {{ section.settings.color_btn }};
    letter-spacing: 1px;
  }
  .section-banner-v5 .banner-item .banner-content .btn-banner-{{ section.id }}:hover {
    background: {{ section.settings.bg_btn_hover }};
    color: {{ section.settings.color_btn_hover }};
    border: 1px solid {{ section.settings.bg_btn_hover }};
  }

</style>

