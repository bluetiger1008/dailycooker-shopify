<div data-section-id="{{ section.id }}" data-section-type="section-blog-v2" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-blog-v2 mt-all" >
    <div class="container container-v1">
	
      {% if section.settings.section_title != blank %}
      <div class="text-center ">            
        <h3 class="title_heading mb-0" >{{ section.settings.section_title }}</h3>            
      </div>
      {% endif %}
      
        <div class="row js-blog-v2 content-blog-v2">
          {%- assign posts_limit = section.settings.blogs_limit -%}
          {%- assign blog_selected = section.settings.select_blog -%}
          {% if section.settings.select_blog != blank %}
          {% for article in blogs[blog_selected].articles limit: posts_limit %}

          <div class="col-12">
            <div class="content-section-blog-v2">
              <div class="picrure">
                <a href="{{ article.url }}"  class="image_url">
                  <img loading="lazy" width="" height="" data-src="{{ article.image.src | image_url: width: 1024, height: 1024 }}" alt="{{ article.title }}" class="lazyload img-fluid">
                </a>				
              </div>

              {% if section.settings.enable_date == true %}
              <div class="info_blog">                
                <div class="date item-blog">
                  <div class="day"><span>{{ article.published_at | date: " %d" }}</span></div>
                  <div class="month"><span>{{ article.published_at | date: "%b" }}</span></div>
                </div>
                <div class="box-info_blog item-blog">
                  {% if section.settings.enable_category %}
                  <a class="blog_cate" href="{{ blogs[blog_selected].url }}">{{ blogs[blog_selected].title }}</a>
                  {% endif %}
                  {% if section.settings.enable_title %}
                  <h4 class="mb-0 title-blog"><a href="{{ article.url }}">{{ article.title }}</a></h4>
                  {% endif %}
                  {% if section.settings.enable_excerpt %}
                  <p class="content mb-0">
                    {{ article.content | strip_html | truncatewords: 22 }}
                  </p>
                  {% endif %}

                  {% if section.settings.text_btn != blank %}
                  <div class="btn_readmore">
                    <a class="" href="{{ article.url }}">{{ section.settings.text_btn }}</a>
                  </div>
                  {% endif %}
                </div>
              </div>
              
              {% else %}
              <div class="info_blog info2">                
                <div class="box-info_blog">
                  {% if section.settings.enable_category %}
                  <a class="blog_cate" href="{{ blogs[blog_selected].url }}">{{ blogs[blog_selected].title }}</a>
                  {% endif %}
                  {% if section.settings.enable_title %}
                  <h4 class="mb-0 title-blog"><a href="{{ article.url }}">{{ article.title }}</a></h4>
                  {% endif %}
                  {% if section.settings.enable_excerpt %}
                  <p class="content mb-0">
                    {{ article.content | strip_html | truncatewords: 22 }}
                  </p>
                  {% endif %}

                  {% if section.settings.text_btn != blank %}
                  <div class="btn_readmore">
                    <a class="" href="{{ article.url }}">{{ section.settings.text_btn }}</a>
                  </div>
                  {% endif %}
                </div>
                
              </div>
              
              {% endif %}
              

            </div>
          </div>                
          {% endfor %}
          {% else %}
          {% for i in (1..6) %}
          <div class="col-12">
            <div class="content-section-blog-v2">
              <div class="picrure">
                <a href="/admin/articles"  class="image_url">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </a>
              </div>
              <div class="info_blog"> 
                <div class="date item-blog">
                  <div class="day"><span>{{ 'now' | date: " %d" }}</span></div>
                  <div class="month"><span>{{ 'now' | date: "%b" }}</span></div>
                </div>


                <div class="box-info_blog item-blog">
                  <h4 class="mb-0 title-blog"><a href="/admin/articles">Example Blog Post</a></h4>
                  <p class="content mb-0">
                    Rapidiously monetize resource sucking main tainable catalysts for change. Conveniently productivate researched action items via go...
                  </p>
                  <div class="btn_readmore">
                    <a class="" href="">Readmore</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {% endfor %} 
          {% endif %}

      </div> 

    </div>
  </div>
</div>
{% schema %}
{
  "name": "BLOG V2",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "header",
      "content": "Settings Blog"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "INSPIRATION"
    },
    {
      "type": "header",
      "content": "Setting Blog"
    },
    {
      "type": "blog",
      "id": "select_blog",
      "label": "Select Blog"
    },
    {
      "type": "header",
      "content": "Info Blogs"
    },
    {
      "type": "range",
      "id": "blogs_limit",
      "label": "Limit blogs",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_category",
      "label": "Show Category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_date",
      "label": "Show Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "text",
      "id": "text_btn",
      "label": "Text Button",
      "default": "Readmore"
    }
  ],
  "presets": [
    {
      "name": "BLOG V2",
      "category": "HOME"
    }
  ]
}
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}