<div data-section-id="{{ section.id }}" data-section-type="section-banner-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v1">
    <div class="row align-items-center no-gutters"  style="background: {{ section.settings.bg_info }}">
      <div class="col-12 col-md-6">
        <div class="picture" style="background-image: url({% if section.settings.banner_img != blank %}{{ section.settings.banner_img | image_url }}{% else %}//via.placeholder.com/800x1000{% endif %})">
          <div class="images">
            {% if section.settings.banner_img != blank %}
            <img loading="lazy" width="" height="" data-src="{{ section.settings.banner_img | image_url }}" class="lazyload img-fluid w-100" alt="_img">
            {% else %}
            <img loading="lazy" width="" height="" data-src="//via.placeholder.com/800x800" class="lazyload img-fluid w-100" alt="_img">
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">    
        <div class="banner-info">
          {% if section.settings.title_top != blank %}
          <p class="title-top" style="color: {{ section.settings.color_title_top }}">
            {{ section.settings.title_top }}
          </p>
          {% endif %}

          {% if section.settings.title_banner != blank %}
          <h3 class="title-banner" style="color: {{ section.settings.color_title }}">
            {{ section.settings.title_banner }}
          </h3>
          {% endif %}

          {% if section.settings.subtitle_banner != blank %}
          <p class="subtitle-banner" style="color: {{ section.settings.color_subtitle }}">
            {{ section.settings.subtitle_banner }}
          </p>
          {% endif %}

          <div class="wrap-item">
            {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
            {% if block.type == 'item' %}
            <div class="item-banner">
              <div class="icon-info">
                {% if block.settings.img_item != blank %}
                <img loading="lazy" width="" height="" data-src="{% if block.settings.img_item != blank %} {{ block.settings.img_item | image_url }} {% endif %}" class="lazyload img-fluid" alt="_img_icon_banner">
                {% endif %}
              </div>
              <div class="item-info">
                {% if block.settings.title_item != blank %}
                <h3 class="title-item mb-0" style="color: {{ block.settings.color_title }}">{{ block.settings.title_item }}</h3>
                {% endif %}
              </div>

            </div>
            {% endif %}
            {% endfor %}
            {% endif %}
          </div>

        </div>

      </div>
    </div>

  </div>
</div>
{% schema %}
{
  "name": "BANNER V1",
  "settings": [
    {
      "type": "header",
      "content": "Banner Left"
    },
    {
      "type": "image_picker",
      "id": "banner_img",
      "label": "Image left",
      "info": "800 x 800px recommended"
    },
    {
      "type": "header",
      "content": "Info Right"
    },
    {
      "type": "color",
      "id": "bg_info",
      "label": "Background Color",
      "default": "#eef1f9"
    },
    {
      "type": "text",
      "id": "title_top",
      "label": "Title Top",
      "default": "A LITTLE ABOUT US"
    },
    {
      "type": "color",
      "id": "color_title_top",
      "label": "Color",
      "default": "#909090"
    },
    {
      "type": "text",
      "id": "title_banner",
      "label": "Title banner",
      "default": "WHY CHOOSE US"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Color",
      "default": "#000"
    },
    {
      "type": "text",
      "id": "subtitle_banner",
      "label": "Sub Title",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut elit tellus, luctus nec ullamcorper mattis, pulvinar dapibus leo. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut elit tellus, luctus nec ullamcorper mattis, pulvinar dapibus leo."
    },
    {
      "type": "color",
      "id": "color_subtitle",
      "label": "Color",
      "default": "#909090"
    },
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "img_item",
          "label": "Image",
          "info": "40 x 40px recommended"
        },
        {
          "type": "text",
          "id": "title_item",
          "label": "Title Item",
          "default": "100% Payment Secure"
        },
        {
          "type": "color",
          "id": "color_title",
          "label": "Color",
          "default": "#909090"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BANNER V1",
      "category": "HOME",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title_item": "EXPRESS SHIPPING"
          }
        },
        {
          "type": "item",
          "settings": {
            "title_item": "QUICK INSTALLATION"
          }
        },
        {
          "type": "item",
          "settings": {
            "title_item": "30 DAY RETURN POLICY"
          }
        }
      ]
    }
  ]
}
{% endschema %}

