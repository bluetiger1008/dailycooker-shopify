<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{% for block in section.blocks %}
{% if block.type == "slideshow" %}
  {% if block.settings.fonts_title != blank %}
  <link href="https://fonts.googleapis.com/css2?family={{ block.settings.fonts_sub_1 }}:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  {% endif %}
  {% if block.settings.fonts_description != blank %}
  <link href="https://fonts.googleapis.com/css2?family={{ block.settings.fonts_sub_2 }}:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  {% endif %}
  {% if block.settings.fonts_button != blank %}
  <link href="https://fonts.googleapis.com/css2?family={{ block.settings.fonts_button }}:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  {% endif %}
{% endif %}
{% endfor %}
<div data-section-id="{{ section.id }}" data-section-type="section-slideshow-v4" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-slideshow-v4">
    <div class="container container-v1">
      <div class="slick-slide-h4 js-slideshow-v4">       
        {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
        {% if block.type == "slideshow" %}
        <div class="item-slide">
          <div class="info-slide">
            <div class="picture-slideshow">
              {% if block.settings.block_bg_image != blank %}
              <img loading="lazy" width="" height="" src="{{ block.settings.block_bg_image | image_url }}" class="img-fluid w-100" alt="slideshow">
              {% else %}
              <img loading="lazy" width="" height="" src="//via.placeholder.com/1500x700" class="img-fluid w-100" alt="slideshow">
              {% endif %}
            </div>

            <div class="box-content">
              {% if block.settings.block_title or block.settings.block_sub_title or block.settings.block_desc or block.settings.block_buton != blank %}
              <div class="box-info box-info-{{ block.id }} {% if block.settings.select_textalign_content == 'left' %} text-left {% elsif block.settings.select_textalign_content == 'center' %} text-center {% else %} text-right {% endif %}">                          
                {% if block.settings.block_title != blank %}
                <div class="box-title box-title-{{ block.id }} animated">
                  <h2 class="title-slide" style="color:{{ block.settings.color_block_title }};">{{ block.settings.block_title }}</h2>
                </div>
                {% endif %}

                {% if block.settings.block_desc != blank %}
                <div class="box-desc box-desc-{{ block.id }} animated">
                  <p class="mb-0" style="color:{{ block.settings.color_block_desc }};">{{ block.settings.block_desc }}</p>
                </div>
                {% endif %}


                {% if block.settings.block_buton != blank %}
                <div class="box-button">
                  <a class="button-main1 button-shop-{{ block.id }}  animated" href="{{ block.settings.block_url }}">
                    {{ block.settings.block_buton }}
                  </a>
                </div>
                {% endif %}

              </div>
              {% endif %}
            </div>          
          </div>
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}

      </div>
    </div>
  </div>
</div>
<style>
  {% for block in section.blocks %}
  {% if block.type == 'slideshow' %}
  .section-slideshow-v4 .item-slide .info-slide .box-content .box-button .button-shop-{{ block.id }} {
    color : {{ block.settings.color_button }};
    background: {{ block.settings.bg_color_button }};
  }
  .section-slideshow-v4 .item-slide .info-slide .box-content .box-button .button-shop-{{ block.id }}:hover{
    color : {{ block.settings.color_button_hover }};
    background: {{ block.settings.bg_color_button_hover }};
  }
  
  
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-title-{{block.id}}{    
    -webkit-animation-name: {{ block.settings.effect_title }};
    animation-name:  {{ block.settings.effect_title }}; ;
  }
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-desc-{{block.id}}{     
    -webkit-animation-name: {{ block.settings.effect_des }};
    animation-name:  {{ block.settings.effect_des }}; ;
  }
  
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .button-shop-{{block.id}}{      
    -webkit-animation-name: {{ block.settings.effect_button }};
    animation-name:  {{ block.settings.effect_button }}; ;
  }
  
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-title-{{block.id}}{    
    {% if block.settings.fonts_title != blank %}
      font-family: '{{ block.settings.fonts_title }}';
        {% endif %}
  }
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-desc-{{block.id}}{     
    {% if block.settings.fonts_description != blank %}
      font-family: '{{ block.settings.fonts_description }}';
        {% endif %}
  }
  
  .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .button-shop-{{block.id}}{      
    -webkit-animation-name: {{ block.settings.fonts_button }};
    animation-name:  {{ block.settings.fonts_button }}; ;
  }
  
  @media(min-width:1900px){
    .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-title-{{block.id}}{   
      font-size:{{ block.settings.font_size_title }}px;
    }
    .section-slideshow-v4 .slick-active .info-slide .box-info-{{ block.id }} .box-desc-{{block.id}} {    
      font-size:{{ block.settings.font_size_des }}px;
    }
    .section-slideshow-v4 .slick-active .info-sideh2 .box-info-{{ block.id }} .btn-animation-{{block.id}} .button-main1{   
      font-size:{{ block.settings.font_size_button }}px;
    }
  }

  {% endif %}
  {% endfor %}
</style>
