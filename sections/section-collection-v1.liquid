<div data-section-id="{{ section.id }}" data-section-type="section-collection-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-collection-v1 mt-all">
    <div class="lazyload">
      <div class="container container-v2">
        <div class="text-center">
          {% if section.settings.title_heading != blank %}
          <h3 style="color: {{ section.settings.color_title }}">
            {{ section.settings.title_heading }}
          </h3>
          {% endif %}
          {% if section.settings.subtitle_heading != blank %}
          <p class="subtitle_heading mb-0" style="color: {{ section.settings.color_subtitle }}">
            {{ section.settings.subtitle_heading }}
          </p>
          {% endif %}
        </div>
        <div class="row no-gutters js-collection-v1">
          {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
          {% if block.type == 'colection' %}
          <div class="col-12 col-item">
            <div class="item">
              <div class="box-img">
                <a href="{{ block.settings.block_url }}" title="{{ block.settings.block_title }}">
                  {% if block.settings.block_img != blank %}
                  <img loading="lazy" width="" height="" data-src="{{ block.settings.block_img | image_url }}" class="lazyload img-fluid w-100" alt="collection">
                  {% else %}
                  <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/200x200" class="lazyload img-fluid w-100" alt="collection">
                  {% endif %}
                </a>
              </div>
              <div class="category-info">
                <div class="box-info">
                  {% if block.settings.block_title != blank %}
                  <a href="{{ block.settings.block_url }}" class="title-collection">{{ block.settings.block_title }}</a>
                  {% endif %}
                  {% if block.settings.block_content != blank %}
                  <p class="content-box mb-0">{{ block.settings.block_content }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
          {% endif %}
          {% endfor %}
          {% endif %} 
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "COLLECTION V1",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "title_heading",
      "label": "Title Heading",
      "default": "THE BEST GETAWAY"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Color Title Heading",
      "default": "#FF4545"
    },
    {
      "type": "text",
      "id": "subtitle_heading",
      "label": "Sub Title Heading",
      "default": "NOT YOUR EVERYDAY SPA"
    },
    {
      "type": "color",
      "id": "color_subtitle",
      "label": "Color Sub Title Heading",
      "default": "#FF4545"
    },
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "colection",
      "name": "Item Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "block_img",
          "info": "200 x 200px recommended",
          "label": "Collection 1"
        },
        {
          "type": "text",
          "id": "block_title",
          "label": "Label Collection",
          "default": "Massage Therapy"
        },
        {
          "type": "url",
          "id": "block_url",
          "label": "URL collection",
          "default": "/collections/all"
        },
        {
          "type": "text",
          "id": "block_content",
          "label": "Content",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "COLLECTION V1",
      "category": "HOME",
      "blocks": [
        {
          "type": "colection",
          "settings": {
            "block_title": "Massage Therapy",
            "block_content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          }
        },
        {
          "type": "colection",
          "settings": {
            "block_title": "Skin Care",
            "block_content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          }
        },
        {
          "type": "colection",
          "settings": {
            "block_title": "Body Treatments",
            "block_content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          }
        }
      ]
    }
  ]
}
{% endschema %}


