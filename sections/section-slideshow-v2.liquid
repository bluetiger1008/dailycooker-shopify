<div data-section-id="{{ section.id }}" data-section-type="section-slideshow-v2" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{% endif %} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{ section.settings.sections_bg_color }};{% endif %}">
  <div class="section-slideshow-v2">
      <div class="slick-side-h2 js-slideshow-v2">       
        {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
        {% if block.type == "slideshow" %}
        <div class="itemv-slide-h2">
          <div class="info-sideh2">
            <div class="picture-slideshow">
              {% if block.settings.block_banerimage != blank %}
              <img loading="lazy" width="" height="" src="{{ block.settings.block_banerimage | image_url }}" class="img-fluid img_slideh2" alt="{{ block.settings.block_banerimage.alt | escape }}">
              {% endif %}
            </div>
         
            <div class="box-content">                          
              
              {% if block.settings.block_title_top != blank %}
              <div class="box-title">
                <h3 class="title1" style="color:{{ block.settings.color_block_title_top }};">{{ block.settings.block_title_top }}</h3>
              </div>
              {% endif %} 
              
              {% if block.settings.block_title_top2 != blank %}
              <div class="box-title">
                <h3 class="title2" style="color:{{ block.settings.color_block_title_top }};">{{ block.settings.block_title_top2 }}</h3>
              </div>
              {% endif %}
              
              {% if block.settings.block_subtitle != blank %}
              <div class="box-contentp">
                 <p class="mb-0" style="color:{{ block.settings.color_subtitle }};">{{ block.settings.block_subtitle }}</p>
              </div>
              {% endif %}
              
              <div class="box-button">
                {% if block.settings.block_buton != blank %}
                <a class="button-main1 button-shop-{{ block.id }}" href="{{ block.settings.block_url }}">
                  {{ block.settings.block_buton }}
                </a>
                {% endif %}
              </div>
              
            </div>            
            <div class="picture_left col-lg-6 col-8 order-1 order-lg-2" data-tilt style>
              {% if block.settings.block_picture_left != blank %}
              <img loading="lazy" width="" height="" src="{{ block.settings.block_picture_left | image_url }}" class="slideshow-v2-picture-left-img" alt="">
              {% else %}
              <img loading="lazy" width="" height="" src="//via.placeholder.com/766x780" class="slideshow-v2-picture-left-img" alt="">
              {% endif %}
            </div>            
          </div>
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}
        
      </div>
  </div>
</div>
<style>
  {% for block in section.blocks %}
  {% if block.type == 'slideshow' %}
  .section-slideshow-v2 .itemv-slide-h2 .info-sideh2 .box-content .box-button .button-shop-{{ block.id }} {
    color : {{ block.settings.color_button }};
    background-color: {{ block.settings.bg_color_button }};
  }
  .section-slideshow-v2 .itemv-slide-h2 .info-sideh2 .box-content .box-button .button-shop-{{ block.id }}:hover {
    color : {{ block.settings.color_button_hover }};
    background-color: {{ block.settings.bg_color_button_hover }};
  }

  {% endif %}
  {% endfor %}
</style>
{% schema %}
{
  "name": "SLIDESHOW V2",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "slideshow",
      "name": "Slideshow",
      "settings": [
        {
          "type": "image_picker",
          "id": "block_banerimage",
          "label": "Background slideshow",
          "info": "1920 x 1071px recommended"
        },
        {
          "type": "text",
          "id": "block_title_top",
          "label": "Title sideshow top",
          "default": "Kitchen Knife"
        },
        {
          "type": "text",
          "id": "block_title_top2",
          "label": "Title sideshow top 2",
          "default": "Collectionb Design"
        },
        {
          "type": "color",
          "id": "color_block_title_top",
          "label": "Color Title sideshow top",
          "default": "#000"
        },
        {
          "type": "text",
          "id": "block_subtitle",
          "label": "Sub Title sideshow",
          "default": "from $69"
        },
        {
          "type": "color",
          "id": "color_subtitle",
          "label": "Color Sub Title sideshow",
          "default": "#000"
        },
        {
          "type": "text",
          "id": "block_buton",
          "label": "Button slideshow",
          "default": "Shop now"
        },
        {
          "type": "header",
          "content": "Background & color button"
        },
        {
          "type": "color",
          "id": "color_button",
          "label": "Color button",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "bg_color_button",
          "label": "Background Color button",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "color_button_hover",
          "label": "Color button hover",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "bg_color_button_hover",
          "label": "Background Color button hover",
          "default": "#f8c461"
        },
        {
          "type": "url",
          "id": "block_url",
          "label": "URL button slideshow",
          "default": "/collections/all"
        },
        {
          "type": "image_picker",
          "id": "block_picture_left",
          "label": "Image left",
          "info": "760 x 787px png recommended"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SLIDESHOW V2",
      "category": "HOME",
      "blocks": [
        {
          "type": "slideshow",
          "settings": {
            "block_title_top": "Kitchen Knife",
            "block_title_top2": "Collection Design",
            "block_subtitle": "from $69",
            "block_buton": "Shop now"
          }
        },
        {
          "type": "slideshow",
          "settings": {
            "block_title_top": "Pressure Cooker",
            "block_title_top2": "Mini Sale",
            "block_subtitle": "from $80",
            "block_buton": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}


